# FTDI FT2232H USB permissions
# Copy to /etc/udev/rules.d/99-ftdi.rules

SUBSYSTEM=="usb", ATTRS{idVendor}=="0403", ATTRS{idProduct}=="6010", MODE="0666", GROUP="plugdev"

# Also handle tty devices if kernel driver is loaded
SUBSYSTEM=="tty", ATTRS{idVendor}=="0403", ATTRS{idProduct}=="6010", MODE="0666", GROUP="plugdev"
